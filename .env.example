# -------------------------------------------------------------
# GigShield AI – Environment Variables
# Copy this file to .env and fill in your actual API keys.
# -------------------------------------------------------------

# ==========================================
# 1. FRONTEND CONFIG
# ==========================================
# The public API URL for Next.js to call the backend
NEXT_PUBLIC_API_URL=http://localhost:8000
# Razorpay public key ID for frontend checkout mock
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_YourKeyIdHere

# ==========================================
# 2. BACKEND API KEYS (TriggerAgent & PayoutAgent)
# ==========================================
# OpenWeatherMap API Key (Free tier works) - Required for rain/heat triggers
OPENWEATHERMAP_API_KEY=your_owm_api_key_here

# NewsAPI Key (Free tier works) - Required for curfew/strike triggers
NEWSAPI_KEY=your_newsapi_key_here

# Razorpay API Keys (Sandbox/Test mode) - Required for mock UPI payouts
RAZORPAY_KEY_ID=rzp_test_YourKeyIdHere
RAZORPAY_KEY_SECRET=your_razorpay_secret_here

# Firebase Server Key (Optional) - For push notifications
FIREBASE_SERVER_KEY=your_firebase_server_key_here

# ==========================================
# 3. BLOCKCHAIN CONFIG
# ==========================================
# Hardhat local testnet RPC URL
HARDHAT_RPC_URL=http://127.0.0.1:8545
# Address of deployed ClaimLedger.sol (run `cd blockchain && npm run deploy` to get this)
CLAIM_LEDGER_ADDRESS=

# ==========================================
# 4. DATABASE CONFIG
# ==========================================
# SQLite for local dev. Use postgresql+asyncpg://user:pass@host/db for production.
DATABASE_URL=sqlite+aiosqlite:///./gigshield.db

# ==========================================
# 5. TRIGGER THRESHOLDS (Optional overrides)
# ==========================================
RAIN_THRESHOLD_MM=15
HEAT_THRESHOLD_C=42
AQI_THRESHOLD=300
TRIGGER_POLL_INTERVAL=600 # 10 minutes in seconds
